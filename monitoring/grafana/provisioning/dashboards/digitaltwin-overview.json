{
  "dashboard": {
    "id": null,
    "uid": "digitaltwin-overview",
    "title": "Digital Twin - Overview",
    "tags": ["digitaltwin"],
    "timezone": "utc",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Request Rate (req/s)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(http_requests_received_total{job=\"digitaltwin-api\"}[5m])",
            "legendFormat": "{{method}} {{code}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 2,
        "title": "Request Latency (p50 / p95 / p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"digitaltwin-api\"}[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"digitaltwin-api\"}[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"digitaltwin-api\"}[5m]))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 3,
        "title": "Error Rate (5xx)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_received_total{job=\"digitaltwin-api\",code=~\"5..\"}[5m])) / sum(rate(http_requests_received_total{job=\"digitaltwin-api\"}[5m])) * 100",
            "legendFormat": "Error %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Active Conversations",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
        "targets": [
          {
            "expr": "digitaltwin_active_conversations",
            "legendFormat": "Active"
          }
        ]
      },
      {
        "id": 5,
        "title": "Emotion Fusion Latency",
        "type": "timeseries",
        "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(digitaltwin_emotion_fusion_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 Fusion"
          },
          {
            "expr": "histogram_quantile(0.95, rate(digitaltwin_message_latency_seconds_bucket[5m]))",
            "legendFormat": "p95 Message"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 6,
        "title": "LLM Response Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(digitaltwin_llm_response_duration_seconds_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(digitaltwin_llm_response_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 7,
        "title": "WebSocket Connections",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "digitaltwin_websocket_connections_active",
            "legendFormat": "Active WS"
          },
          {
            "expr": "rate(digitaltwin_websocket_connections_total[5m])",
            "legendFormat": "New/s"
          }
        ]
      },
      {
        "id": 8,
        "title": "Usage Limits - Requests by Tier",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "targets": [
          {
            "expr": "sum by (tier) (rate(digitaltwin_usage_requests_total[5m]))",
            "legendFormat": "{{tier}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 9,
        "title": "Database Query Duration",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(db_client_operation_duration_bucket{job=\"digitaltwin-api\"}[5m]))",
            "legendFormat": "p95 DB"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      }
    ]
  },
  "overwrite": true
}
