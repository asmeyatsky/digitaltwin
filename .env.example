# Digital Twin Emotional Companion — Environment Variables
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit your .env file to version control

# ============================================================
# ENVIRONMENT
# ============================================================
ASPNETCORE_ENVIRONMENT=Development

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DB_NAME=digitaltwin
DB_USER=dtadmin
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
DB_UID=999
DB_GID=999
# Standardized connection string used by .NET API
ConnectionStrings__DefaultConnection=Host=postgres;Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD}

# ============================================================
# REDIS
# ============================================================
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_STRONG_PASSWORD

# ============================================================
# RABBITMQ
# ============================================================
RABBITMQ_USER=dtadmin
RABBITMQ_PASSWORD=CHANGE_THIS_RABBITMQ_STRONG_PASSWORD

# ============================================================
# JWT AUTHENTICATION
# ============================================================
# Generate with: openssl rand -base64 64
JwtConfiguration__SecretKey=GENERATE_WITH_openssl_rand_base64_64
JwtConfiguration__Issuer=DigitalTwin
JwtConfiguration__Audience=DigitalTwin
JwtConfiguration__ExpiryInMinutes=60

# ============================================================
# SERVICE URLs (used by API gateway to call microservices)
# ============================================================
Services__DeepFace__BaseUrl=http://deepface:8001
Services__Avatar__BaseUrl=http://avatar-generation:8002
Services__Voice__BaseUrl=http://voice-service:8003
Services__LLM__BaseUrl=http://llm-service:8004

# ============================================================
# CORS
# ============================================================
CORS__AllowedOrigins=http://localhost:3000,http://localhost:8081,http://localhost:19006

# ============================================================
# EXTERNAL API KEYS
# ============================================================
ELEVENLABS_API_KEY=CHANGE_THIS_ELEVENLABS_API_KEY
OPENAI_API_KEY=CHANGE_THIS_OPENAI_API_KEY

# ============================================================
# SERVICE-TO-SERVICE AUTH
# ============================================================
SERVICE_API_KEY=GENERATE_WITH_openssl_rand_hex_32
CORS_ORIGINS=http://localhost:8080

# ============================================================
# MONITORING (internal only, no host port mapping in production)
# ============================================================
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD

# ============================================================
# OBJECT STORAGE
# ============================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_PASSWORD

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=Information
LOG_PATH=./logs
LOG_RETENTION_DAYS=30

# ============================================================
# SECURITY
# ============================================================
ENABLE_HTTPS=false
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ============================================================
# TESTING
# ============================================================
TEST_DATABASE_NAME=digitaltwin_test
TEST_REDIS_DB=1

# ============================================================
# DEVELOPMENT ONLY — disable all of these in production
# ============================================================
DEBUG_MODE=true
ENABLE_SWAGGER=true
# DEV_TEST_PASSWORD= (set for dev-mode AuthController login)

# ============================================================
# CI/CD
# ============================================================
DOCKER_REGISTRY=ghcr.io/asmeyatsky/digitaltwin
# GITHUB_TOKEN= (set in CI secrets, not here)

# ============================================================
# ENVIRONMENT-SPECIFIC NOTES
# ============================================================
# For staging: override DB_NAME, REDIS, RABBITMQ hosts via separate .env.staging
# For production: override via .env.production or Kubernetes ConfigMap/Secrets
# Never use shell conditionals in .env files — they are not valid syntax
